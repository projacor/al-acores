# Postgres (Railway injeta automaticamente DATABASE_URL no projeto)
DATABASE_URL=postgresql://user:pass@localhost:5432/al_acores

# Email (Resend) — relatório diário de suspeitos
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=alertas@exemplo.pt
EMAIL_TO=destino@exemplo.pt

# Proteção do dashboard e do disparo manual do scan
DASHBOARD_PASSWORD=muda-isto
RUN_TOKEN=token-secreto-para-/api/run

# Limites do scraper (úteis para testes locais)
# MAX_LISTINGS limita o nº de anúncios novos processados por execução (0 = sem limite)
MAX_LISTINGS=0
# Ilhas a pesquisar (vírgulas). Vazio = todas. Ex.: "Corvo,Flores" para testar rápido.
ILHAS=
# Atraso entre páginas do Booking, em ms (rate-limit)
SCRAPE_DELAY_MS=4000
